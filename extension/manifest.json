{
  "manifest_version": 3,
  "name": "Recomendador Semantico de Tesis",
  "version": "1.0.0",
  "description": "Asistente de investigacion inteligente con indexacion semantica.",
  "action": {
    "default_title": "Abrir recomendador semantico"
  },
  "icons": {
    "16": "icons/icono.png",
    "32": "icons/icono.png",
    "48": "icons/icono.png",
    "128": "icons/icono.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://repositorio.unap.edu.pe/*",
    "https://repositorio.unsa.edu.pe/*",
    "https://repositorio.unsaac.edu.pe/*",
    "https://tamoil13-unap-research-ml.hf.space/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://repositorio.unap.edu.pe/*",
        "https://repositorio.unsa.edu.pe/*",
        "https://repositorio.unsaac.edu.pe/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "panel.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
